{
	"name": "rovy-physics-controller",
	"version": "0.0.0",
	"description": "Physics controller package for Rovy",
	"main": "out/init.luau",
	"types": "out/index.d.ts",
	"license": "MIT",
	"scripts": {
		"build": "rbxtsc",
		"dev": "rbxtsc -w",
		"test": "npm run build && zune test test/run",
		"build:playtest": "npm run build && mkdir -p build && rojo build playtest.project.json -o build/rovy-physics-controller-playtest.rbxl"
	},
	"files": [
		"out",
		"!**/*.tsbuildinfo"
	],
	"publishConfig": {
		"access": "public"
	},
	"dependencies": {
		"@rovy/core": "workspace:*",
		"@rovy/jecs": "workspace:*",
		"@rovy/networking": "workspace:*",
		"@rovy/ui": "workspace:*",
		"@rovy/world-inspector": "workspace:*",
		"typescript": "5.5.3"
	},
	"devDependencies": {
		"@rbxts/compiler-types": "3.0.0-types.0",
		"@rbxts/types": "^1.0.920",
		"roblox-ts": "^3.0.0",
		"rovy-transformer": "workspace:*"
	}
}
